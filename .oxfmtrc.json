{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "printWidth": 80,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "insertFinalNewline": true,
  "sortPackageJson": true,
  "ignorePatterns": [
    "package-lock.json",
    "yarn.lock",
    ".yarn/sdks",
    "dist",
    "graphify-out",
    "node_modules"
  ]
}
