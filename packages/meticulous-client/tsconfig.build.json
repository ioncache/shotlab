{
  "extends": "./tsconfig.json",
  "include": ["./src/**/*"],
  "exclude": [
    "./src/**/*.test.ts",
    "./src/integration-config.ts",
    "./test/**/*",
    "./dist/**/*"
  ],
  "compilerOptions": {
    "incremental": false,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"]
  }
}
